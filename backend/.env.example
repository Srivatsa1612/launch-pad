# Server Configuration
PORT=3001
NODE_ENV=development

# Microsoft Fabric Configuration
# Choose your authentication method:
# - 'user' for personal access token (default) - See FABRIC_AUTH_GUIDE.md
# - 'service-principal' for automated/production use
FABRIC_AUTH_TYPE=user

# For USER authentication (FABRIC_AUTH_TYPE=user):
# Get a fresh token: npm run get-token
LIVY_ENDPOINT=https://api.fabric.microsoft.com/v1/workspaces/YOUR_WORKSPACE_ID/lakehouses/YOUR_LAKEHOUSE_ID/livyapi/versions/2023-12-01/sessions
FABRIC_TOKEN=your-token-here
WORKSPACE_ID=your-workspace-id
LAKEHOUSE_ID=your-lakehouse-id

# For SERVICE PRINCIPAL authentication (FABRIC_AUTH_TYPE=service-principal):
# Uncomment and configure these - See FABRIC_AUTH_GUIDE.md for setup
# AZURE_CLIENT_ID=your-application-client-id
# AZURE_CLIENT_SECRET=your-application-client-secret
# AZURE_TENANT_ID=your-azure-tenant-id

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
